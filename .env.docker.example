APP_PORT=8080
TZ=America/Sao_Paulo

# Copie este arquivo para .env no servidor e troque todos os segredos.
# Nunca versione o .env real.

POSTGRES_DB=iedc
POSTGRES_USER=iedc_app
POSTGRES_PASSWORD=troque_esta_senha_forte

# Banco isolado do Albergue. Use senha diferente da senha do banco principal.
POSTGRES_ALBERGUE_DB=iedc_albergue
POSTGRES_ALBERGUE_USER=iedc_albergue_app
POSTGRES_ALBERGUE_PASSWORD=troque_esta_senha_albergue

# Cadastro mestre e departamentos institucionais. Nao reutilize senhas de outros bancos.
POSTGRES_MASTER_DB=iedc_master
POSTGRES_MASTER_USER=iedc_master_app
POSTGRES_MASTER_PASSWORD=troque_esta_senha_master

# Banco isolado da Escola. Nao reutilize senhas de outros bancos.
POSTGRES_ESCOLA_DB=iedc_escola
POSTGRES_ESCOLA_USER=iedc_escola_app
POSTGRES_ESCOLA_PASSWORD=troque_esta_senha_escola

# Banco oficial: migrations controlam o schema. Nao habilite synchronize em producao.
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

# Observabilidade local: logs estruturados, lentidao e status operacional.
APP_VERSION=v1.0.0-iedc
LOG_LEVEL=log
LOG_FORMAT=json
LOG_INCLUDE_STACK=false
SLOW_REQUEST_MS=500
VERY_SLOW_REQUEST_MS=1000
BACKUP_STALE_AFTER_HOURS=30

JWT_SECRET=troque_por_um_segredo_longo_e_unico
JWT_EXPIRES_IN=12h
IEDC_DEFAULT_PASSWORD=troque_esta_senha_inicial

# Proteção contra abuso de API e força bruta no login.
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=5

# Use CORS_ORIGIN somente se houver um frontend externo ao Nginx do compose.
# Exemplo: http://192.168.0.10
CORS_ORIGIN=
ENABLE_SWAGGER=false
ENABLE_DEMO_SEED=false
ENABLE_MAINTENANCE_ROUTES=false

# Integrações opcionais
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_EQUIPE=
TELEGRAM_GROUP_COORDENACAO=
TELEGRAM_GROUP_GERAL=
RESEND_API_KEY=
RESEND_FROM=
TRIAGEM_EMAIL_DESTINATION=
TRIAGEM_NOTIFICATION_INCLUDE_PII=false

# Backup remoto opcional via rclone crypt.
# Exemplo: iedc-drive-crypt:Backups Sistema IEDC
BACKUP_ROOT=/var/backups/iedc
BACKUP_STATUS_PATH=/var/backups/iedc/backup-status.json
RESTORE_STATUS_PATH=/var/backups/iedc/restore-status.json
RCLONE_DESTINATION=
BACKUP_RETENTION_DAYS=30
