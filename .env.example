# ============================================================
# IEDC 360 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com segredos reais.
# ============================================================

# Porta exposta pelo Docker (frontend)
APP_PORT=8080

# Fuso horário
TZ=America/Sao_Paulo

# ---- Banco de dados principal (core) ----
POSTGRES_DB=iedc
POSTGRES_USER=iedc_app
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA

# ---- Banco de dados do albergue ----
POSTGRES_ALBERGUE_DB=iedc_albergue
POSTGRES_ALBERGUE_USER=iedc_albergue_app
POSTGRES_ALBERGUE_PASSWORD=TROQUE_ESTA_SENHA

# ---- Banco de dados master (identidade compartilhada) ----
POSTGRES_MASTER_DB=iedc_master
POSTGRES_MASTER_USER=iedc_master_app
POSTGRES_MASTER_PASSWORD=  # deixe vazio para usar POSTGRES_PASSWORD

# ---- Banco de dados da escola ----
POSTGRES_ESCOLA_DB=iedc_escola
POSTGRES_ESCOLA_USER=iedc_escola_app
POSTGRES_ESCOLA_PASSWORD=  # deixe vazio para usar POSTGRES_PASSWORD

# ---- TypeORM ----
# NUNCA use true em produção — usa migrações explícitas
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

# ---- JWT ----
# Gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_ESTE_SEGREDO
JWT_EXPIRES_IN=12h

# ---- Senha inicial do usuário suporte ----
# Será exigida troca no primeiro login
IEDC_DEFAULT_PASSWORD=TROQUE_ESTA_SENHA

# ---- CORS (deixe vazio para rede local / sem acesso externo) ----
# Com domínio externo: CORS_ORIGIN=https://sistema.iedc.org.br
CORS_ORIGIN=

# ---- Swagger (false em produção) ----
ENABLE_SWAGGER=false

# ---- Seeds e rotas de manutenção (false em produção) ----
ENABLE_DEMO_SEED=false
ENABLE_MAINTENANCE_ROUTES=false

# ---- Telegram (opcional — notificações de triagem) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_EQUIPE=
TELEGRAM_GROUP_COORDENACAO=
TELEGRAM_GROUP_GERAL=

# ---- E-mail via Resend (opcional — notificações de triagem) ----
RESEND_API_KEY=
RESEND_FROM=
TRIAGEM_EMAIL_DESTINATION=
# true envia nomes no corpo do e-mail (atenção à LGPD)
TRIAGEM_NOTIFICATION_INCLUDE_PII=false

# ---- Backups ----
BACKUP_ROOT=/var/backups/iedc
BACKUP_STATUS_PATH=/var/backups/iedc/backup-status.json
RESTORE_STATUS_PATH=/var/backups/iedc/restore-status.json
BACKUP_STALE_AFTER_HOURS=30
