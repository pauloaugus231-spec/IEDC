# ==================================
# TELEGRAM BOT CONFIGURATION
# ==================================

# Token do bot (obtenha com @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# IDs dos grupos (use /chatid no bot para descobrir)
TELEGRAM_GROUP_EQUIPE=-1001234567890
TELEGRAM_GROUP_COORDENACAO=-1001234567891  
TELEGRAM_GROUP_GERAL=-1001234567892

# ==================================
# COMO CONFIGURAR:
# ==================================
# 1. Fale com @BotFather no Telegram
# 2. Digite /newbot
# 3. Escolha um nome e username
# 4. Copie o token e cole em TELEGRAM_BOT_TOKEN
# 5. Adicione o bot nos grupos desejados
# 6. No grupo, digite /chatid
# 7. O bot responderá com o ID do chat
# 8. Cole os IDs nas variáveis acima
