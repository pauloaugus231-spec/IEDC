# ============================================
# CONFIGURAÇÃO: PRONTUÁRIO AUTOMÁTICO
# ============================================

# Habilitar/Desabilitar criação automática de prontuário
# ao finalizar atendimento no Espaço de Cuidados
# Valores: true (padrão) | false
ESPACO_CUIDADOS_CRIAR_PRONTUARIO=true

# ============================================
# INSTRUÇÕES DE USO
# ============================================

# 1. HABILITAR (padrão):
#    ESPACO_CUIDADOS_CRIAR_PRONTUARIO=true
#    → Prontuário será criado automaticamente ao finalizar atendimento
#
# 2. DESABILITAR:
#    ESPACO_CUIDADOS_CRIAR_PRONTUARIO=false
#    → Prontuário NÃO será criado automaticamente
#
# 3. NÃO DEFINIR (padrão = true):
#    Se a variável não estiver no .env, o comportamento padrão é criar

# ============================================
# O QUE É SALVO NO PRONTUÁRIO AUTOMÁTICO?
# ============================================
# - Pessoa atendida
# - Data do atendimento
# - Equipe presente
# - Serviços realizados (banho e/ou atendimento)
# - Tempos de cada etapa (chegada, início/fim banho, início/fim atendimento)
# - Duração em minutos (banho, atendimento, total)
# - Indicadores (novo cadastro, passou vez)
# - Observações registradas

# ============================================
# COMO VERIFICAR SE FUNCIONOU?
# ============================================
# 1. Acesse: GET /api/prontuarios/pessoa/:pessoa_id
# 2. Verifique o campo "criado_automaticamente": true
# 3. Verifique o campo "modulo_origem": "espaco_cuidados"
# 4. Verifique o campo "referencia_externa": <sessao_id>
